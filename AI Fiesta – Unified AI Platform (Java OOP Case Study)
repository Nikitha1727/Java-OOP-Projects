// AIFiesta
class AIFiesta {

    HashMap<String,User> registeredUsers
            = new HashMap<>();

    ArrayList<String> promptHistory
            = new ArrayList<>();

    public void registerUser(User user) {

        registeredUsers.put(
        user.getUserName(),
        user);
    }

    public void processPrompt(
            String userName,
            AIModel model,
            String prompt)

            throws InsufficientTokensException {

        User user =
        registeredUsers.get(userName);

        int cost =
        model.getTokenCost();

        if(user.getAvailableTokens()
                < cost) {

            throw new
            InsufficientTokensException(
            "Insufficient Tokens");
        }

        model.generateResponse(prompt);

        user.setAvailableTokens(
        user.getAvailableTokens()
        - cost);

        promptHistory.add(prompt);

        System.out.println(
        "Remaining Tokens : "
        + user.getAvailableTokens());
    }

    public void displayPromptHistory() {

        System.out.println(
        "\nPrompt History");

        for(String p : promptHistory) {

            System.out.println(p);
        }
    }
}

// Main Class
public class Main {

    public static void main(String[] args) {

        AIFiesta fiesta =
                new AIFiesta();

        User u1 =
        new User("Nikitha");

        User u2 =
        new User(
        "Rahul",
        "rahul@gmail.com");

        User u3 =
        new User(
        "Admin",
        "admin@gmail.com",
        "Enterprise");

        fiesta.registerUser(u1);
        fiesta.registerUser(u2);
        fiesta.registerUser(u3);

        AIModel chatgpt =
                new ChatGPT();

        AIModel gemini =
                new Gemini();

        AIModel claude =
                new Claude();

        try {

            chatgpt.displayModelDetails();

            fiesta.processPrompt(
            "Nikitha",
            chatgpt,
            "Explain OOP");

            gemini.displayModelDetails();

            fiesta.processPrompt(
            "Rahul",
            gemini,
            "What is Java?");

            claude.displayModelDetails();

            fiesta.processPrompt(
            "Admin",
            claude,
            "Generate Report");

        }

        catch(
        InsufficientTokensException e) {

            System.out.println(
            e.getMessage());
        }

        fiesta.displayPromptHistory();
    }
}
