import java.util.*;

// Custom Exception
class InsufficientTokensException extends Exception {
    public InsufficientTokensException(String msg) {
        super(msg);
    }
}

// User Class (Encapsulation + Constructor Overloading)
class User {

    private String userName;
    private String emailId;
    private String subscriptionPlan;
    private int availableTokens;

    // Constructor 1
    public User(String userName) {
        this.userName = userName;
        this.emailId = "Not Provided";
        this.subscriptionPlan = "Free";
        allocateTokens();
    }

    // Constructor 2
    public User(String userName, String emailId) {
        this.userName = userName;
        this.emailId = emailId;
        this.subscriptionPlan = "Free";
        allocateTokens();
    }

    // Constructor 3
    public User(String userName, String emailId,
                String subscriptionPlan) {
        this.userName = userName;
        this.emailId = emailId;
        this.subscriptionPlan = subscriptionPlan;
        allocateTokens();
    }

    private void allocateTokens() {
        switch(subscriptionPlan) {
            case "Pro":
                availableTokens = 1000;
                break;

            case "Enterprise":
                availableTokens = 5000;
                break;

            default:
                availableTokens = 100;
        }
    }

    public String getUserName() {
        return userName;
    }

    public int getAvailableTokens() {
        return availableTokens;
    }

    public void setAvailableTokens(int tokens) {
        availableTokens = tokens;
    }
}

// Interface
interface AIService {
    void generateResponse(String prompt);
}

// Abstract Class
abstract class AIModel implements AIService {

    protected String modelName;
    protected String provider;

    public AIModel(String modelName,
                   String provider) {

        this.modelName = modelName;
        this.provider = provider;
    }

    public void displayModelDetails() {

        System.out.println("Model : "
                           + modelName);

        System.out.println("Provider : "
                           + provider);
    }

    public abstract int getTokenCost();
}

// ChatGPT
class ChatGPT extends AIModel {

    public ChatGPT() {
        super("ChatGPT","OpenAI");
    }

    public void generateResponse(String prompt) {
        System.out.println(
        "ChatGPT processed : " + prompt);
    }

    public int getTokenCost() {
        return 20;
    }
}

